// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Custom fields
  role          Role      @default(EMPLOYEE)
  managerId     String?
  manager       User?     @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates  User[]    @relation("ManagerSubordinates")
  goals         Goal[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Goal {
  id          String    @id @default(cuid())
  title       String
  description String
  uom         UoM
  target      Float
  weightage   Float
  status      GoalStatus @default(DRAFT)
  achievement Float?
  checkinComment String?
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])
  thrustArea  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lockedAt    DateTime?
  sharedGoalId String?
  sharedGoal  SharedGoal? @relation(fields: [sharedGoalId], references: [id])
}

model SharedGoal {
  id          String   @id @default(cuid())
  title       String
  description String
  target      Float
  createdBy   String // Could be Admin or Manager ID
  createdAt   DateTime @default(now())
  goals       Goal[]
}

model AuditLog {
  id        String   @id @default(cuid())
  goalId    String
  changedBy String // User ID
  change    String
  createdAt DateTime @default(now())
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum UoM {
  NUMERIC
  PERCENTAGE
  TIMELINE
  ZERO_BASED
}

enum GoalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED // Returned for rework
  NOT_STARTED
  ON_TRACK
  COMPLETED
}